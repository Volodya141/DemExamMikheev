<Window x:Class="BurgerPlusManagementSystem.Windows.UserEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BurgerPlusManagementSystem.Windows"
        mc:Ignorable="d"
        Title="Окно Редактирования/Добавления"
        Height="560"
        MinHeight="560"
        Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="Фамилия" FontSize="17"/>
            <TextBox x:Name="tbSecondName" Height="30" Margin="0,5,0,10" VerticalContentAlignment="Center" FontSize="17"/>
            <TextBlock Text="Имя" FontSize="17"/>
            <TextBox x:Name="tbFirstName" Height="30" Margin="0,5,0,10" VerticalContentAlignment="Center" FontSize="17"/>
            <TextBlock Text="Отчество" FontSize="17"/>
            <TextBox x:Name="tbPatronymic" Height="30" Margin="0,5,0,10" VerticalContentAlignment="Center" FontSize="17"/>
            <TextBlock Text="Логин" FontSize="17"/>
            <TextBox x:Name="tbLogin" Height="30" Margin="0,5,0,10" VerticalContentAlignment="Center" FontSize="17"/>
            <TextBlock Text="Пароль" FontSize="17"/>
            <PasswordBox x:Name="pbPassword" Height="30" Margin="0,5,0,10" VerticalContentAlignment="Center" FontSize="17"/>
            <TextBlock Text="Роль" FontSize="17"/>
            <ComboBox x:Name="cbRole" DisplayMemberPath="RoleName" SelectedValuePath="RoleID" Height="30" Margin="0,5,0,10" Background="White" FontSize="17"/>
            <CheckBox x:Name="chBlocked" Content="Заблокирован" FontSize="17"/>
        </StackPanel>
        <Button Grid.Row="1" Height="40" Content="Сохранить" Click="BtnSave_Click" Background="LightGreen" FontSize="17"/>
    </Grid>
</Window>

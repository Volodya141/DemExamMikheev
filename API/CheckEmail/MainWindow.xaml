<Window x:Class="CheckEmail.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CheckEmail"
        mc:Ignorable="d"
        Title="Валидация данных"
        Height="250" MaxHeight="250" MinHeight="250"
        Width="750" MaxWidth="750" MinWidth="750"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0 0 0 20">

                <Button x:Name="GetDataButton"
                        Content="Получить данные"
                        Width="250"
                        Height="60"
                        FontSize="20"
                        Click="GetDataButton_Click"/>

                <TextBlock x:Name="txtBoxEmailText"
                           Width="400"
                           VerticalAlignment="Center"
                           Margin="20 0 0 0"
                           FontSize="24"
                           TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Button x:Name="CheckButton"
                        Content="Отправить результат теста"
                        Width="250"
                        Height="60"
                        FontSize="18"
                        Click="CheckButton_Click"/>

                <TextBlock x:Name="txtBoxResultText"
                           Width="400"
                           VerticalAlignment="Center"
                           Margin="20 0 0 0"
                           FontSize="22"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>

